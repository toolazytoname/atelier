#!/usr/bin/env bash
# devbox — host-side wrapper around the OrbStack atelier VM.
#
# Routes every command into the VM so all dev work stays sandboxed. Mirrors
# host env (ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN, etc.) into the VM via
# /etc/environment.d/.
#
# Usage:
#   devbox status                # show VM state
#   devbox shell                 # open an interactive shell
#   devbox run <cmd>             # run a command (shorthand for orb run)
#   devbox claude                # run Claude Code entirely inside the VM
#   devbox gui                   # open open-design Electron GUI from VM
#   devbox push <file>           # copy file/folder into VM home
#   devbox pull <file>           # copy from VM home to cwd
#   devbox provision             # re-run setup/provision.sh inside VM
#   devbox reset                 # destroy + recreate the VM (DESTRUCTIVE)
#   devbox doctor                # check host + VM health
#
# Self-contained: pure bash, no Node/Rust deps. Auto-installs to ~/bin.
set -euo pipefail

VM_NAME="${DEVBOX_VM:-atelier}"
VM_CPUS="${DEVBOX_CPUS:-4}"
VM_MEMORY="${DEVBOX_MEMORY:-8G}"
VM_DISK="${DEVBOX_DISK:-64G}"
VM_DISTRO="${DEVBOX_DISTRO:-ubuntu:24.04}"

# ---------------------------------------------------------------------------
# helpers
# ---------------------------------------------------------------------------
# JSON=0 by default. Set to 1 by the top-level `--json` flag.
JSON=0

log() {
  [[ $JSON -eq 1 ]] && return 0
  printf '\033[1;34m[devbox]\033[0m %s\n' "$*"
}

warn() {
  [[ $JSON -eq 1 ]] && return 0
  printf '\033[1;33m[devbox]\033[0m %s\n' "$*" >&2
}

die() {
  local msg="$*"
  if [[ $JSON -eq 1 ]]; then
    # JSON envelope. Requires jq; caller should have already validated.
    jq -nc \
      --arg command "${CMD_NAME:-help}" \
      --arg vm "$VM_NAME" \
      --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      --arg msg "$msg" \
      '{ok: false, command: $command, vm: $vm, timestamp: $ts, exit_code: 1, error: $msg}'
  else
    printf '\033[1;31m[devbox]\033[0m %s\n' "$msg" >&2
  fi
  exit 1
}

# In --json mode, bail with a clear plain-text error if jq is missing
# (so the agent gets a readable signal rather than an empty stream).
require_jq() {
  if ! command -v jq >/dev/null 2>&1; then
    printf '[devbox] --json mode requires jq (install: brew install jq)\n' >&2
    exit 2
  fi
}

# now_ms: integer milliseconds since epoch.
#
# macOS BSD date doesn't support %N (nanoseconds), so we use python3
# (always present on macOS) for sub-second precision. The python
# startup cost (~30 ms) is dwarfed by the subprocess cost on the
# other side of the timing window, so this is fine.
now_ms() { python3 -c 'import time; print(int(time.time()*1000))'; }

# ---------------------------------------------------------------------------
# prerequisites
# ---------------------------------------------------------------------------
require_orb() {
  if ! command -v orbctl >/dev/null 2>&1 && ! command -v orb >/dev/null 2>&1; then
    die "OrbStack not found. Install: brew install --cask orbstack"
  fi
  # Use orbctl explicitly so 'orb run' doesn't shadow the prefix form
  export PATH="/opt/homebrew/bin:$PATH"
  if ! command -v orbctl >/dev/null 2>&1; then
    # shellcheck disable=SC2155
    export PATH="$(dirname "$(command -v orb)"):$PATH"
  fi
}

vm_exists() { orbctl list 2>/dev/null | awk '{print $1}' | grep -qx "$VM_NAME"; }
vm_running() { orbctl list 2>/dev/null | awk '$2=="running" {print $1}' | grep -qx "$VM_NAME"; }

ensure_vm() {
  require_orb
  if ! vm_exists "$VM_NAME"; then
    log "VM $VM_NAME not found — creating $VM_DISTRO (cpus=$VM_CPUS mem=$VM_MEMORY disk=$VM_DISK)"
    orbctl create --cpus "$VM_CPUS" --memory "$VM_MEMORY" --disk "$VM_DISK" "$VM_DISTRO" "$VM_NAME"
  fi
  if ! vm_running "$VM_NAME"; then
    log "starting $VM_NAME"
    orbctl start "$VM_NAME" >/dev/null
  fi
}

# ---------------------------------------------------------------------------
# subcommands
# ---------------------------------------------------------------------------
cmd_status() {
  require_orb
  orbctl info "$VM_NAME" 2>/dev/null || die "VM $VM_NAME not found (try: devbox reset)"
}

cmd_shell() {
  ensure_vm
  exec orbctl shell "$VM_NAME"
}

cmd_run() {
  ensure_vm
  if [[ $# -eq 0 ]]; then
    exec orbctl shell "$VM_NAME"
  fi
  orbctl run -m "$VM_NAME" "$@"
}

cmd_push() {
  ensure_vm
  [[ $# -ge 1 ]] || die "usage: devbox push <file-or-dir> [dest]"
  local src="$1" dest="${2:-.}"
  orbctl push -m "$VM_NAME" "$src" "$dest"
}

cmd_pull() {
  ensure_vm
  [[ $# -ge 1 ]] || die "usage: devbox pull <vm-path> [local-dest]"
  local src="$1" dest="${2:-.}"
  orbctl pull -m "$VM_NAME" "$src" "$dest"
}

cmd_provision() {
  ensure_vm
  local script="/mnt/mac/Users/lazy/Code/crack/claude/atelier/setup/provision.sh"
  [[ -f "$script" ]] || die "provision script not found at $script"
  log "running provision.sh inside $VM_NAME"
  orbctl run -m "$VM_NAME" bash "$script"
}

# Run Claude Code entirely inside the VM. The host becomes a thin display
# terminal: no tools, no plugins, no MCP servers — those all live in the VM
# and are shared with the host via /mnt/mac.
cmd_claude() {
  ensure_vm
  local extra=()
  for v in ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN ANTHROPIC_API_KEY \
           API_TIMEOUT_MS GITHUB_TOKEN; do
    [[ -n "${!v-}" ]] && extra+=("$v=${!v}")
  done

  log "launching claude inside $VM_NAME (host is now just a display terminal)"
  # Daemon + CC share one orb run so they live and die together. The daemon
  # is a background process inside the same VM shell; CC talks to it via the
  # local MCP (.mcp.json) over loopback. Ctrl-C kills the whole group.
  # shellcheck disable=SC2016  # $VAR expansion happens on the VM, not here
  exec orbctl run -m "$VM_NAME" "${extra[@]}" bash -lc '
    export PATH="$HOME/.local/bin:/usr/local/node-v24.11.0-linux-arm64/bin:$PATH"
    cd "/mnt/mac/Users/lazy/Code/crack/atelier"

    # Start the open-design daemon in the background of THIS shell, so the
    # MCP bridge is alive while CC runs. The MCP itself is stdio (od mcp),
    # not HTTP, so no token / port binding is needed.
    if ! pgrep -f "od.mjs" >/dev/null 2>&1; then
      echo "[devbox] starting open-design daemon"
      nohup ~/.local/bin/od start >~/.local/share/open-design/daemon.log 2>&1 &
      disown
      # Give it a moment to bind 127.0.0.1:7456 before CC connects.
      for i in 1 2 3 4 5; do
        pgrep -f "od.mjs" >/dev/null 2>&1 && break
        sleep 1
      done
    fi
    od status 2>&1 | sed "s/^/  /"

    exec claude "$@"
  ' _ "$@"
}

# Forward the open-design web UI from the VM to the host browser via an
# SSH tunnel through OrbStack. The daemon lives in a background `orb run`
# so it survives the SSH session handshake; killing the foreground ssh
# process tears the tunnel down and the daemon exits with the orb run.
cmd_gui() {
  ensure_vm
  local port="${DEVBOX_GUI_PORT:-7456}"
  log "tunneling VM's :$port → host's :$port (Ctrl-C to stop)"
  log "then open: http://localhost:$port"

  # Start the daemon in its own long-lived `orb run` (it stays alive for
  # the duration of the tunnel). Bind only to loopback — the SSH tunnel
  # is what bridges traffic to the host.
  # shellcheck disable=SC2016  # $VAR expansion happens on the VM, not here
  orbctl run -m "$VM_NAME" bash -lc '
    export PATH="$HOME/.local/bin:$PATH"
    if ! pgrep -f "od.mjs" >/dev/null 2>&1; then
      echo "[devbox] starting open-design daemon"
      nohup ~/.local/bin/od start >~/.local/share/open-design/daemon.log 2>&1 &
      disown
      for i in 1 2 3 4 5; do
        pgrep -f "od.mjs" >/dev/null 2>&1 && break
        sleep 1
      done
    fi
    od status 2>&1 | sed "s/^/  /"
    echo "[devbox] daemon ready on 127.0.0.1:'"$port"'. Ctrl-C the bin/devbox gui process to stop the tunnel."
    exec sleep infinity
  ' &
  local daemon_pid=$!

  # Tidy up on Ctrl-C. Single quotes so $daemon_pid is evaluated when the
  # trap fires (not now at trap-set time).
  trap 'kill "$daemon_pid" 2>/dev/null; wait "$daemon_pid" 2>/dev/null' EXIT INT TERM

  # OrbStack exposes Linux VMs as `user@machine@orb` over SSH.
  ssh -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/dev/null \
      -N -L "${port}:127.0.0.1:${port}" "${USER}@${VM_NAME}@orb"
  kill $daemon_pid 2>/dev/null
  wait $daemon_pid 2>/dev/null
}

cmd_reset() {
  require_orb
  warn "this will DELETE the VM $VM_NAME and recreate it from scratch"
  warn "all uncommitted work inside the VM will be lost"
  read -rp "type 'yes' to continue: " confirm
  [[ "$confirm" == "yes" ]] || { log "aborted"; exit 0; }
  if vm_exists "$VM_NAME"; then
    log "deleting $VM_NAME"
    orbctl delete "$VM_NAME" --force 2>/dev/null || true
  fi
  log "creating $VM_NAME"
  orbctl create --cpus "$VM_CPUS" --memory "$VM_MEMORY" --disk "$VM_DISK" "$VM_DISTRO" "$VM_NAME"
  cmd_provision
}

cmd_doctor() {
  local ok=1
  printf '%-22s ' "orbstack:"
  if command -v orbctl >/dev/null 2>&1; then
    printf "OK (%s)\n" "$(orbctl --help 2>&1 | head -1 || true)"
  else
    printf "MISSING — brew install --cask orbstack\n"; ok=0
  fi

  printf '%-22s ' "vm $VM_NAME:"
  if vm_exists "$VM_NAME"; then
    if vm_running "$VM_NAME"; then
      printf "running\n"
    else
      printf "stopped\n"
    fi
  else
    printf "not created — run: devbox provision\n"; ok=0
  fi

  printf '%-22s ' "shared mount:"
  if orbctl run -m "$VM_NAME" test -d /mnt/mac 2>/dev/null; then
    printf "OK (/mnt/mac)\n"
  else
    printf "missing — VM not running or non-OrbStack backend\n"; ok=0
  fi

  printf '%-22s ' "host env passthrough:"
  if orbctl run -m "$VM_NAME" test -f "/home/$(whoami)/.config/environment.d/host-proxy.conf" 2>/dev/null; then
    printf "installed\n"
  else
    printf "missing — run: ./setup/host-passthrough.sh\n"; ok=0
  fi

  return $((1 - ok))
}

# ---------------------------------------------------------------------------
# JSON variants (only invoked when --json is set; default is human-readable)
#
# Output envelope (single line, parseable by jq):
#   {ok, command, vm, timestamp, exit_code, duration_ms, ...extras}
# ---------------------------------------------------------------------------

# cmd_status_json: structured VM state for programmatic consumers.
cmd_status_json() {
  require_orb
  require_jq
  CMD_NAME="status"
  local start_ms end_ms raw rc
  start_ms=$(now_ms)
  raw=$(orbctl info "$VM_NAME" 2>&1) || rc=$? && rc=${rc:-0}
  rc=${rc:-0}
  end_ms=$(now_ms)

  local name distro arch status_line
  name=$(printf '%s\n' "$raw"     | awk -F': *' '/^Name:/   {print $2; exit}')
  distro=$(printf '%s\n' "$raw"   | awk -F': *' '/^Distro:/ {print $2; exit}')
  arch=$(printf '%s\n' "$raw"     | awk -F': *' '/^Architecture:/ {print $2; exit}')
  status_line=$(printf '%s\n' "$raw" | awk -F': *' '/^State:/ {print $2; exit}')

  local exists="false" running="false" ok="false"
  [[ -n "$name" ]]      && exists="true"
  [[ "$status_line" == "running" ]] && { running="true"; ok="true"; }

  jq -nc \
    --arg command "status" \
    --arg vm "$VM_NAME" \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --argjson ok "$ok" \
    --argjson exit_code "$rc" \
    --argjson duration_ms "$(( end_ms - start_ms ))" \
    --arg raw "$raw" \
    --arg name "$name" \
    --arg distro "$distro" \
    --arg arch "$arch" \
    --arg status "$status_line" \
    --argjson exists "$exists" \
    --argjson running "$running" \
    '{ok: $ok, command: $command, vm: $vm, timestamp: $ts,
      exit_code: $exit_code, duration_ms: $duration_ms,
      exists: $exists, running: $running,
      name: $name, distro: $distro, arch: $arch, status: $status,
      raw: $raw}'
}

# cmd_run_json: capture stdout/stderr of the inner command, return JSON.
cmd_run_json() {
  ensure_vm
  require_jq
  CMD_NAME="run"
  local start_ms end_ms rc cmd_str
  local tmp_err
  tmp_err=$(mktemp -t devbox.XXXXXX.err) || die "mktemp failed"
  # shellcheck disable=SC2064
  trap "rm -f '$tmp_err'" EXIT
  cmd_str="$*"
  start_ms=$(now_ms)
  local stdout_text
  if stdout_text=$(orbctl run -m "$VM_NAME" "$@" 2>"$tmp_err"); then
    rc=0
  else
    rc=$?
  fi
  end_ms=$(now_ms)
  local stderr_text
  stderr_text=$(cat "$tmp_err" 2>/dev/null || true)
  rm -f "$tmp_err"
  trap - EXIT

  local ok="false"
  [[ $rc -eq 0 ]] && ok="true"

  jq -nc \
    --arg command "run" \
    --arg vm "$VM_NAME" \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --argjson ok "$ok" \
    --argjson exit_code "$rc" \
    --argjson duration_ms "$(( end_ms - start_ms ))" \
    --arg cmd "$cmd_str" \
    --arg stdout "$stdout_text" \
    --arg stderr "$stderr_text" \
    '{ok: $ok, command: $command, vm: $vm, timestamp: $ts,
      exit_code: $exit_code, duration_ms: $duration_ms,
      cmd: $cmd, stdout: $stdout, stderr: $stderr}'
}

# cmd_doctor_json: structured health checks for programmatic consumers.
cmd_doctor_json() {
  require_jq
  CMD_NAME="doctor"
  local start_ms end_ms
  start_ms=$(now_ms)
  local overall_ok="true"

  local orb_ok="false" orb_detail="" vm_ok="false" vm_state="missing" \
       vm_detail="" mount_ok="false" mount_detail="" \
       passthrough_ok="false" passthrough_detail=""

  if command -v orbctl >/dev/null 2>&1; then
    orb_ok="true"
    orb_detail=$(orbctl --help 2>&1 | head -1 || true)
  else
    overall_ok="false"
    orb_detail="missing — brew install --cask orbstack"
  fi

  if vm_exists "$VM_NAME"; then
    if vm_running "$VM_NAME"; then
      vm_ok="true"
      vm_state="running"
      vm_detail="running"
    else
      vm_state="stopped"
      vm_detail="stopped — start with: bin/devbox run ..."
      overall_ok="false"
    fi
  else
    vm_detail="not created — run: bin/devbox provision"
    overall_ok="false"
  fi

  if [[ "$vm_state" == "running" ]] \
     && orbctl run -m "$VM_NAME" test -d /mnt/mac 2>/dev/null; then
    mount_ok="true"
    mount_detail="/mnt/mac"
  else
    mount_detail="missing — VM not running or non-OrbStack backend"
    [[ "$vm_state" == "running" ]] && overall_ok="false"
  fi

  if [[ "$vm_state" == "running" ]] \
     && orbctl run -m "$VM_NAME" test -f "/home/$(whoami)/.config/environment.d/host-proxy.conf" 2>/dev/null; then
    passthrough_ok="true"
    passthrough_detail="installed"
  else
    passthrough_detail="missing — run: ./setup/host-passthrough.sh"
    [[ "$vm_state" == "running" ]] && overall_ok="false"
  fi

  end_ms=$(now_ms)

  jq -nc \
    --arg command "doctor" \
    --arg vm "$VM_NAME" \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --argjson ok "$overall_ok" \
    --argjson duration_ms "$(( end_ms - start_ms ))" \
    --argjson orb_ok "$orb_ok" \
    --arg orb_detail "$orb_detail" \
    --argjson vm_ok "$vm_ok" \
    --arg vm_state "$vm_state" \
    --arg vm_detail "$vm_detail" \
    --argjson mount_ok "$mount_ok" \
    --arg mount_detail "$mount_detail" \
    --argjson passthrough_ok "$passthrough_ok" \
    --arg passthrough_detail "$passthrough_detail" \
    '{ok: $ok, command: $command, vm: $vm, timestamp: $ts,
      duration_ms: $duration_ms,
      checks: {
        orbstack:          {ok: $orb_ok,          detail: $orb_detail},
        vm:                {ok: $vm_ok, state: $vm_state, detail: $vm_detail},
        shared_mount:      {ok: $mount_ok,        detail: $mount_detail},
        host_env_passthrough: {ok: $passthrough_ok, detail: $passthrough_detail}
      }}'
}

# ---------------------------------------------------------------------------
# dispatch
# ---------------------------------------------------------------------------

# Global --json flag (must come before the subcommand).
[[ "${1:-}" == "--json" ]] && { JSON=1; shift; }

# In --json mode, validate jq up front so missing-jq produces a clear error
# rather than a confusing failure mid-envelope.
[[ $JSON -eq 1 ]] && require_jq

CMD_NAME="${1:-help}"

case "${1:-help}" in
  status)    shift; if [[ $JSON -eq 1 ]]; then cmd_status_json "$@"; else cmd_status "$@"; fi ;;
  shell)     shift; cmd_shell "$@" ;;
  run)       shift; if [[ $JSON -eq 1 ]]; then cmd_run_json "$@";   else cmd_run "$@";   fi ;;
  push)      shift; cmd_push "$@" ;;
  pull)      shift; cmd_pull "$@" ;;
  provision) shift; cmd_provision "$@" ;;
  claude)    shift; cmd_claude "$@" ;;
  gui)       shift; cmd_gui "$@" ;;
  reset)     shift; cmd_reset "$@" ;;
  doctor)    shift; if [[ $JSON -eq 1 ]]; then cmd_doctor_json "$@"; else cmd_doctor "$@"; fi ;;
  help|--help|-h|*)
    sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'
    ;;
esac
